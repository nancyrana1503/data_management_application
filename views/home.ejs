<!DOCTYPE html>
<html>
<head>
  <title>Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <div class="container mt-5 text-center">

    <!-- Card with limited width -->
    <div class="card p-5 shadow mx-auto" style="max-width: 500px;">

      <h1 class="mb-3">Task Management App</h1>
      <p class="mb-4">Manage your tasks efficiently with a secure authentication system. <br>
        This application uses MongoDB to handle user accounts and PostgreSQL to store and
        organize your task data reliably.</p>

      <!-- Buttons (fixed size, centered) -->
      <div class="d-flex justify-content-center gap-3">
        <a href="/login" class="btn btn-primary px-4">Login</a>
        <a href="/register" class="btn btn-success px-4">Register</a>
      </div>

    </div>

  </div>

</body>
</html>